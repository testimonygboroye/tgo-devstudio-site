---
interface Props {
  slug: string;
  title: string;
  summary: string;
  tags: string[];
}

const { slug, title, summary, tags } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a
  href={`${base}/portfolio/${slug}`}
  class="group block rounded-2xl p-6 bg-surface/40 backdrop-blur-sm border border-white/10
         shadow-lg shadow-black/20 hover:border-brand-cyan/40 hover:shadow-brand-cyan/10
         transition-all duration-300"
>
  <h3 class="font-display text-lg font-semibold mb-2 text-ink-primary group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-brand-gradient transition-all">
    {title}
  </h3>
  <p class="text-ink-secondary text-sm mb-4">{summary}</p>
  <div class="flex gap-2 flex-wrap">
    {tags.map((tag) => (
      <span class="text-xs bg-white/5 border border-white/10 text-ink-secondary px-2.5 py-1 rounded-full">{tag}</span>
    ))}
  </div>
</a>
