---
const base = import.meta.env.BASE_URL;

const links = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/about`, label: 'About' },
  { href: `${base}/portfolio`, label: 'Portfolio' },
  { href: `${base}/contact`, label: 'Contact' },
];
---

<header class="border-b border-white/10 relative">
  <nav class="max-w-5xl mx-auto flex items-center justify-between px-4 py-4">
    <a href={`${base}/`} class="flex items-center gap-3">
      <img src={`${base}/tgo-logo.png`} alt="TGO DevStudio" class="h-16 w-auto" />
      <span class="font-display font-bold text-2xl md:text-3xl tracking-tight text-ink-primary whitespace-nowrap">
        TGO DevStudio
      </span>
    </a>

    <ul class="hidden md:flex gap-8 text-sm">
      {links.map((link) => (
        <li>
          <a href={link.href} class="text-ink-secondary hover:text-ink-primary transition-colors">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <input type="checkbox" id="nav-toggle" class="peer hidden" />
    <label
      for="nav-toggle"
      class="md:hidden cursor-pointer text-ink-primary text-2xl leading-none select-none px-2"
      aria-label="Toggle menu"
    >
      &#9776;
    </label>

    <div
      class="hidden peer-checked:flex md:hidden flex-col gap-4 absolute top-full left-0 right-0
             bg-surface border-b border-white/10 px-4 py-6 z-10"
    >
      {links.map((link) => (
        <a href={link.href} class="text-ink-secondary hover:text-ink-primary transition-colors">
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>
