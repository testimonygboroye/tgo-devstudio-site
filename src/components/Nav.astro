---
const base = import.meta.env.BASE_URL;

const links = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/about`, label: 'About' },
  { href: `${base}/portfolio`, label: 'Portfolio' },
  { href: `${base}/contact`, label: 'Contact' },
];
---

<header class="border-b border-white/10">
  <nav class="max-w-5xl mx-auto flex items-center justify-between px-4 py-4">
    <a href={`${base}/`} class="flex items-center gap-2">
      <img src={`${base}/tgo-logo.png`} alt="TGO DevStudio" class="h-9 w-9" />
      <span class="font-bold text-lg tracking-tight text-white">TGO DevStudio</span>
    </a>
    <ul class="flex gap-6 text-sm">
      {links.map((link) => (
        <li>
          <a href={link.href} class="text-gray-300 hover:text-white transition-colors">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
