---
import BaseLayout from '../../layouts/BaseLayout.astro';

const apiUrl = import.meta.env.PUBLIC_API_URL;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Accept Invite">
  <section class="max-w-sm mx-auto px-4 py-24">
    <h1 class="font-display text-2xl font-semibold mb-8 text-ink-primary text-center">Set Up Your Account</h1>

    <form id="accept-form" class="space-y-4" novalidate>
      <div>
        <label class="block text-sm font-medium mb-1 text-ink-secondary" for="password">Create a password</label>
        <div class="relative">
          <input type="password" id="password" name="password" class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 pr-16 text-ink-primary" />
          <button type="button" id="toggle-password" class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-ink-secondary hover:text-ink-primary">
            Show
          </button>
        </div>
        <p class="text-xs text-ink-muted mt-1">At least 8 characters.</p>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1 text-ink-secondary" for="confirmPassword">Confirm password</label>
        <input type="password" id="confirmPassword" name="confirmPassword" class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-ink-primary" />
      </div>

      <button type="submit" id="submit-btn" class="w-full px-6 py-3 bg-brand-gradient text-white rounded-lg hover:opacity-90 transition-opacity font-medium disabled:opacity-50">
        Activate account
      </button>

      <div id="form-status" class="text-sm text-center"></div>
    </form>
  </section>
</BaseLayout>

<script define:vars={{ apiUrl, base }}>
  const params = new URLSearchParams(window.location.search);
  const token = params.get('token');
  const email = params.get('email');

  const form = document.getElementById('accept-form');
  const submitBtn = document.getElementById('submit-btn');
  const statusEl = document.getElementById('form-status');
  const passwordInput = document.getElementById('password');
  const toggleBtn = document.getElementById('toggle-password');

  toggleBtn.addEventListener('click', () => {
    const isHidden = passwordInput.type === 'password';
    passwordInput.type = isHidden ? 'text' : 'password';
    toggleBtn.textContent = isHidden ? 'Hide' : 'Show';
  });

  function setStatus(message, type) {
    statusEl.textContent = message;
    statusEl.className = 'text-sm text-center ' + (type === 'error' ? 'text-red-400' : 'text-brand-cyan');
  }

  if (!token || !email) {
    setStatus('This invite link is missing required information.', 'error');
    form.querySelectorAll('input, button[type="submit"]').forEach((el) => (el.disabled = true));
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    setStatus('', '');

    if (form.password.value.length < 8) {
      setStatus('Password must be at least 8 characters.', 'error');
      return;
    }
    if (form.password.value !== form.confirmPassword.value) {
      setStatus('Passwords do not match.', 'error');
      return;
    }

    submitBtn.disabled = true;
    setStatus('Activating...', 'info');

    try {
      const res = await fetch(`${apiUrl}/api/auth/accept-invite`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, token, password: form.password.value }),
      });
      const data = await res.json().catch(() => ({}));

      if (res.ok) {
        setStatus('Account activated! Redirecting to login...', 'success');
        setTimeout(() => {
          window.location.href = `${base}/admin/login`;
        }, 2000);
      } else {
        setStatus(data.error || 'Failed to activate account.', 'error');
        submitBtn.disabled = false;
      }
    } catch (err) {
      setStatus('Network error — please check your connection and try again.', 'error');
      submitBtn.disabled = false;
    }
  });
</script>
