---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Home">
  <section class="max-w-5xl mx-auto px-4 py-24 text-center">
    <h1 class="font-display text-4xl md:text-5xl font-semibold tracking-tight mb-6 text-ink-primary">
      We build world-class software.
    </h1>
    <p class="text-lg text-ink-secondary max-w-2xl mx-auto mb-10">
      TGO DevStudio is the technology sub-brand of TGO — engineering products,
      platforms, and systems that create real value and lasting impact.
    </p>
    <div class="flex gap-4 justify-center">
      <a href={`${base}/portfolio`} class="px-6 py-3 bg-brand-gradient text-white rounded-lg hover:opacity-90 transition-opacity font-medium">
        View our work
      </a>
      <a href={`${base}/about`} class="px-6 py-3 border border-white/20 text-ink-secondary rounded-lg hover:bg-white/5 hover:text-ink-primary transition-colors">
        Our vision
      </a>
    </div>
  </section>
</BaseLayout>
