---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Home">
  <section class="max-w-5xl mx-auto px-4 py-24 text-center">
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-6 text-white">
      We build world-class software.
    </h1>
    <p class="text-lg text-gray-400 max-w-2xl mx-auto mb-10">
      TGO DevStudio is the technology sub-brand of TGO — engineering products,
      platforms, and systems that create real value and lasting impact.
    </p>
    <div class="flex gap-4 justify-center">
      <a href={`${base}/portfolio`} class="px-6 py-3 bg-brand-gradient text-white rounded-lg hover:opacity-90 transition-opacity font-medium">
        View our work
      </a>
      <a href={`${base}/about`} class="px-6 py-3 border border-white/20 text-gray-200 rounded-lg hover:bg-white/5 transition-colors">
        Our vision
      </a>
    </div>
  </section>
</BaseLayout>
