---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact">
  <section class="max-w-xl mx-auto px-4 py-20">
    <h1 class="font-display text-3xl font-semibold mb-8 text-ink-primary">Contact</h1>
    <p class="text-ink-secondary mb-8">
      Interested in working with TGO DevStudio? Send us a message.
    </p>

    <!-- TODO: Replace YOUR_FORM_ID with a real Formspree endpoint before launch.
         This is a temporary placeholder until Phase 2's backend replaces it. -->
    <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-medium mb-1 text-ink-secondary" for="name">Name</label>
        <input type="text" id="name" name="name" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-ink-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1 text-ink-secondary" for="email">Email</label>
        <input type="email" id="email" name="email" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-ink-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1 text-ink-secondary" for="message">Message</label>
        <textarea id="message" name="message" rows="5" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-ink-primary"></textarea>
      </div>
      <button type="submit" class="px-6 py-3 bg-brand-gradient text-white rounded-lg hover:opacity-90 transition-opacity font-medium">
        Send message
      </button>
    </form>
  </section>
</BaseLayout>
